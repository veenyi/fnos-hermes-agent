#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
BIN_DIR="$SCRIPT_DIR/../bin"

OS=$(uname -s)
ARCH=$(uname -m)

case "$OS:$ARCH" in
  Darwin:arm64)
    TARGET="$BIN_DIR/trim-cli-darwin-arm64"
    ;;
  Darwin:x86_64)
    TARGET="$BIN_DIR/trim-cli-darwin-x64"
    ;;
  Linux:x86_64)
    TARGET="$BIN_DIR/trim-cli-linux-x64"
    ;;
  Linux:aarch64|Linux:arm64)
    TARGET="$BIN_DIR/trim-cli-linux-arm64"
    ;;
  *)
    echo "Unsupported platform for ./scripts/trim-cli: $OS $ARCH" >&2
    exit 1
    ;;
esac

if [ ! -x "$TARGET" ]; then
  echo "Missing packaged binary: $TARGET" >&2
  exit 1
fi

exec "$TARGET" "$@"
